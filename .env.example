# Postgres connection strings.
# Local dev uses the Docker container on port 5433.
# On Vercel, set DATABASE_URL to the POOLED connection string and DIRECT_URL to
# the NON-POOLING (direct) connection string from your Vercel Postgres / Neon
# integration. They can be identical for a simple/low-traffic setup.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/survey?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/survey?schema=public"

# ElevenLabs Conversational AI. Create an agent in the ElevenLabs dashboard and
# paste its id here. The API key is server-only and must never be exposed to the
# browser. See docs/elevenlabs-setup.md (added in Phase 3).
ELEVENLABS_API_KEY="your-elevenlabs-api-key"
ELEVENLABS_AGENT_ID="your-elevenlabs-agent-id"
